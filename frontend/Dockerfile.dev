FROM node:lts-alpine3.17

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Set development environment
ENV NODE_ENV development

# Expose development port
EXPOSE 3000

# Pre-bundle deps before dev server (avoids first-run 504 race)
CMD ["sh", "-c", "npx vite optimize && npm run dev -- --host 0.0.0.0"]
